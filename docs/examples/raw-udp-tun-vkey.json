{
  "Devices": [
    {
      "ID": "tun0",
      "Enabled": true,
      "Name": "Raw UDP TUN with vKey",
      "Type": "tun",
      "IfName": "tapx%d",
      "MTU": 1500
    }
  ],
  "VKeys": [
    {
      "ID": "vk0",
      "Enabled": true,
      "Name": "Raw UDP vKey",
      "Value": "tapx-demo-vkey"
    }
  ],
  "Routes": [
    {
      "ID": "route0",
      "Enabled": true,
      "DeviceID": "tun0",
      "VKeyID": "vk0"
    }
  ],
  "Listeners": [
    {
      "ID": "udp-listener-vkey",
      "Enabled": true,
      "Name": "UDP Listener with vKey",
      "BindHost": "127.0.0.1",
      "BindPort": 40001,
      "Transport": "udp",
      "RawUDP": {
        "PeerMode": "learn"
      },
      "Binding": {
        "RouteID": "route0"
      }
    }
  ]
}
