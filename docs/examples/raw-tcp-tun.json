{
  "Devices": [
    {
      "ID": "tun0",
      "Enabled": true,
      "Name": "Raw TCP TUN",
      "Type": "tun",
      "IfName": "tapx%d",
      "MTU": 1500
    }
  ],
  "Routes": [
    {
      "ID": "route0",
      "Enabled": true,
      "DeviceID": "tun0"
    }
  ],
  "Listeners": [
    {
      "ID": "tcp-listener",
      "Enabled": true,
      "Name": "Raw TCP Listener",
      "BindHost": "0.0.0.0",
      "BindPort": 41000,
      "Transport": "tcp",
      "RawTCP": {
        "LengthMode": "uint16",
        "BindAddress": "127.0.0.1",
        "ReceiveBuffer": 65536,
        "SendBuffer": 65536,
        "NoDelay": true,
        "KeepAliveSecond": 30,
        "ConnectTimeout": 3
      },
      "Binding": {
        "RouteID": "route0"
      }
    }
  ]
}
