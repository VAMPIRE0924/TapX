{
  "luci-app-tapx": {
    "description": "Grant access to TapX configuration",
    "read": {
      "uci": [ "tapx" ],
      "file": {
        "/usr/bin/tapx-core": [ "exec" ],
        "/usr/bin/tapx-panel": [ "exec" ],
        "/etc/init.d/tapx": [ "exec" ],
        "/etc/init.d/tapx-panel": [ "exec" ],
        "/usr/libexec/tapx-openwrt-config": [ "exec" ],
        "/sbin/logread": [ "exec" ]
      }
    },
    "write": {
      "uci": [ "tapx" ],
      "file": {
        "/etc/init.d/tapx": [ "exec" ],
        "/etc/init.d/tapx-panel": [ "exec" ],
        "/usr/libexec/tapx-openwrt-config": [ "exec" ],
        "/tmp/tapx-openwrt-restore.tar.gz": [ "write" ]
      }
    }
  }
}
