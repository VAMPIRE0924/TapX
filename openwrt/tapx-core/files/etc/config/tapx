config tapx 'core'
	option enabled '0'
	option autostart '0'
	option config_path '/etc/tapx/runtime.json'
	option respawn_threshold '3600'
	option respawn_timeout '5'
	option respawn_retry '5'

config tapx_runtime 'runtime'

config tapx_panel 'panel'
	option enabled '0'
	option initialized '0'
	option listen_interface ''
	option listen_port ''
	option base_path ''
	option autostart '0'
	option db_path '/etc/tapx/tapx.db'
	option respawn_threshold '3600'
	option respawn_timeout '5'
	option respawn_retry '5'
