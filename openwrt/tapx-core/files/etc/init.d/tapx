#!/bin/sh /etc/rc.common

START=95
STOP=10
USE_PROCD=1

PROG=/usr/bin/tapx-core
DEFAULT_CONFIG=/etc/tapx/runtime.json

start_service() {
	local enabled config_path respawn_threshold respawn_timeout respawn_retry

	config_load tapx
	config_get_bool enabled core enabled 0
	[ "$enabled" = "1" ] || {
		echo "tapx: disabled in /etc/config/tapx"
		return 0
	}

	config_get config_path core config_path "$DEFAULT_CONFIG"
	config_get respawn_threshold core respawn_threshold 3600
	config_get respawn_timeout core respawn_timeout 5
	config_get respawn_retry core respawn_retry 5

	[ -x "$PROG" ] || {
		echo "tapx: missing executable $PROG" >&2
		return 1
	}
	[ -s "$config_path" ] || {
		echo "tapx: missing runtime config $config_path" >&2
		return 1
	}

	procd_open_instance core
	procd_set_param command "$PROG" -config "$config_path"
	procd_set_param respawn "$respawn_threshold" "$respawn_timeout" "$respawn_retry"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger tapx
}
