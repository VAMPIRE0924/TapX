#!/bin/sh /etc/rc.common

START=96
STOP=9
USE_PROCD=1

PROG=/usr/bin/tapx-panel

start_service() {
	local enabled initialized listen_interface listen_port base_path db_path
	local respawn_threshold respawn_timeout respawn_retry

	config_load tapx
	config_get_bool enabled panel enabled 0
	[ "$enabled" = "1" ] || {
		echo "tapx-panel: disabled in /etc/config/tapx"
		return 0
	}

	config_get_bool initialized panel initialized 0
	config_get listen_interface panel listen_interface ''
	config_get listen_port panel listen_port ''
	config_get base_path panel base_path ''
	config_get db_path panel db_path '/etc/tapx/tapx.db'
	config_get respawn_threshold panel respawn_threshold 3600
	config_get respawn_timeout panel respawn_timeout 5
	config_get respawn_retry panel respawn_retry 5

	[ -x "$PROG" ] || {
		echo "tapx-panel: missing executable $PROG" >&2
		return 1
	}
	[ "$initialized" = "1" ] || {
		echo "tapx-panel: initial panel setup is incomplete" >&2
		return 1
	}
	[ -n "$listen_interface" ] && [ -e "/sys/class/net/$listen_interface" ] || {
		echo "tapx-panel: select an existing listen interface" >&2
		return 1
	}
	case "$listen_port" in
		''|*[!0-9]*)
			echo "tapx-panel: listen port must be an integer" >&2
			return 1
			;;
	esac
	[ "$listen_port" -ge 1 ] 2>/dev/null && [ "$listen_port" -le 65535 ] 2>/dev/null || {
		echo "tapx-panel: listen port must be between 1 and 65535" >&2
		return 1
	}
	case "$base_path" in
		/*/) ;;
		*)
			echo "tapx-panel: login path must start and end with /" >&2
			return 1
			;;
	esac
	[ -s "$db_path" ] || {
		echo "tapx-panel: initialized database is missing: $db_path" >&2
		return 1
	}
	mkdir -p "${db_path%/*}"

	procd_open_instance panel
	procd_set_param command "$PROG" \
		-db "$db_path" \
		-listen ":$listen_port" \
		-listen-interface "$listen_interface" \
		-base-path "$base_path"
	procd_set_param respawn "$respawn_threshold" "$respawn_timeout" "$respawn_retry"
	procd_set_param file /etc/config/tapx "$db_path"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

reload_service() {
	stop
	start
}

service_triggers() {
	procd_add_reload_trigger tapx
}
